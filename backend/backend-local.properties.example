# Legacy local override example.
# Prefer using `backend/.env` going forward.

FRONTEND_URL=http://localhost:5173
FRONTEND_LOGIN_URL=http://localhost:5173/login
FRONTEND_OAUTH_SUCCESS_URL=http://localhost:5173/auth/callback
APP_UPLOAD_DIR=./uploads
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
APP_SEED_DEMO_DATA=true
APP_SEED_ADMIN_ACCOUNT=true
APP_DEFAULT_ADMIN_USERNAME=admin
APP_DEFAULT_ADMIN_EMAIL=admin@eduvault.com
APP_DEFAULT_ADMIN_PASSWORD=change-me
JWT_SECRET=replace-with-a-long-random-secret
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/eduvault?createDatabaseIfNotExist=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=replace-me
spring.security.oauth2.client.registration.google.client-id=your-google-client-id.apps.googleusercontent.com
spring.security.oauth2.client.registration.google.client-secret=your-google-client-secret
spring.security.oauth2.client.registration.google.scope=openid,profile,email
spring.security.oauth2.client.registration.google.redirect-uri={baseUrl}/login/oauth2/code/{registrationId}
